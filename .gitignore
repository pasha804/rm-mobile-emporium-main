# ── Dependencies ──────────────────────────────────────────────
node_modules/
backend/node_modules/

# ── Build output ───────────────────────────────────────────────
dist/
dist-ssr/
.output/
.vinxi/
.nitro/
.wrangler/

# ── TanStack Router cache ──────────────────────────────────────
.tanstack/

# ── Logs ───────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Environment variables — NEVER commit these ─────────────────
.env
.env.local
.env.production
backend/.env
.dev.vars

# ── Backend data files — NOT committed to git ──────────────────
# These are created at runtime on the server.
# On Railway: use Railway Volumes or an external DB instead.
# On Hostinger VPS: these live on the server disk.
backend/data/

# ── OS & Editor ────────────────────────────────────────────────
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode/*
!.vscode/extensions.json
.idea/

# ── Lovable.dev editor metadata (not needed outside Lovable) ───
.lovable/

# ── Misc ───────────────────────────────────────────────────────
*.local
bun.lock
